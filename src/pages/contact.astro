  </div>
</section>

<section class="features">
  <div class="container">
    <h2 class="section-title">Как связаться</h2>
    <div class="feature-grid">
      <article class="feature-card">
        <div class="feature-icon">📧</div>
        <h3>Email</h3>
        <a href="mailto:med@beringov.pro">med@beringov.pro</a>
      </article>
      
      <article class="feature-card">
        <div class="feature-icon">✈️</div>
        <h3>Telegram</h3>
        <a href="https://t.me/iberingovpro">@iberingovpro</a>
      </article>
      
      <article class="feature-card">
        <div class="feature-icon">🌐</div>
        <h3>Соцсети</h3>
        <a href="https://www.facebook.com/beringov">Facebook</a>
