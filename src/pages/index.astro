---
import '../styles/main.css';
---

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">
      Создаю <span class="gradient-text">медитации</span><br />
      и редактирую записи
    </h1>
    <p class="hero-subtitle">
      Превращаю ваши идеи в готовые wellness-медитации<br />
      с AI-музыкой и профессиональным звуком
    </p>
    <div class="hero-cta">
      <a href="/services" class="btn btn-primary">Услуги</a>
      <a href="/portfolio" class="btn btn-secondary">Портфолио</a>
    </div>
  </div>
</section>

<section class="features">
  <div class="container">
    <h2 class="section-title">Мои услуги</h2>
    <div class="feature-grid">
      <article class="feature-card">
        <div class="feature-icon">🎙️</div>
        <h3>Монтаж из записей</h3>
        <p>От 5 000₽ • 7 дней</p>
        <ul class="feature-list">
          <li>Обработка голоса</li>
          <li>AI-музыка через Suno</li>
          <li>Мастеринг</li>
        </ul>
        <a href="/contact" class="btn">Заказать</a>
      </article>
      
      <article class="feature-card featured">
        <div class="feature-icon">✨</div>
        <h3>Создание с нуля</h3>
        <p>От 15 000₽ • 10 дней</p>
        <ul class="feature-list">
          <li>Разработка концепции</li>
          <li>3 варианта музыки</li>
          <li>Безлимит правок</li>
        </ul>
        <a href="/contact" class="btn">Заказать</a>
      </article>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>Готовы начать?</h2>
    <a href="/contact" class="btn btn-primary">Отправить заявку</a>
  </div>
</section>